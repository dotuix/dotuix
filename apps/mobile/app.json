{
  "expo": {
    "name": "dotuix viewer",
    "slug": "dotuix-mobile",
    "version": "0.1.0",
    "scheme": "dotuix",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dotuix.mobile",
      "infoPlist": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "UIX Document",
            "CFBundleTypeRole": "Viewer",
            "LSItemContentTypes": [
              "public.data"
            ],
            "LSHandlerRank": "Alternate"
          }
        ]
      }
    },
    "android": {
      "package": "com.dotuix.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f172a"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "mimeType": "application/octet-stream"
            }
          ],
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      [
        "expo-sqlite",
        {
          "useSQLiteCpp": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
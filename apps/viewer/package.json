{
  "name": "@dotuix/viewer",
  "version": "0.3.9",
  "description": "Desktop viewer — Tauri (Rust + WebView)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:compact": "tauri build && pnpm clean:tauri-cache",
    "clean:tauri-cache": "rm -rf src-tauri/target/debug src-tauri/target/release/deps src-tauri/target/release/build src-tauri/target/release/incremental src-tauri/target/release/.fingerprint",
    "vite:dev": "vite",
    "vite:build": "vite build"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "monaco-editor": "^0.52.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0"
  }
}

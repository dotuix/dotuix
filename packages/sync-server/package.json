{
  "name": "@dotuix/sync-server",
  "version": "0.1.0",
  "private": true,
  "description": "Local-sync server for dotuix state — last-write-wins over HTTP",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch & node --watch dist/index.js",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.2",
    "@hono/zod-validator": "^0.4.3",
    "better-sqlite3": "^11.9.1",
    "hono": "^4.7.10",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
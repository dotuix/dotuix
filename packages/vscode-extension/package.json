{
  "name": "dotuix",
  "private": true,
  "displayName": "dotuix",
  "description": "Language support, IntelliSense, and commands for .uix files",
  "version": "0.4.8",
  "publisher": "intenttext",
  "license": "MIT",
  "icon": "icons/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/dotuix/dotuix.git",
    "directory": "packages/vscode-extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "uix",
    "dotuix",
    "kiosk",
    "offline",
    "portable"
  ],
  "activationEvents": [
    "onCustomEditor:dotuix.uixInspector",
    "workspaceContains:**/manifest.json",
    "workspaceContains:**/uix.config.ts",
    "onLanguage:json",
    "onCommand:dotuix.pack",
    "onCommand:dotuix.validate",
    "onCommand:dotuix.init",
    "onChatParticipant:dotuix.create"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dotuix.pack",
        "title": "dotuix: Pack project → .uix"
      },
      {
        "command": "dotuix.validate",
        "title": "dotuix: Validate .uix file"
      },
      {
        "command": "dotuix.init",
        "title": "dotuix: Init new project"
      },
      {
        "command": "dotuix.open",
        "title": "dotuix: Open .uix file in viewer"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "manifest.json",
        "url": "./schemas/manifest.schema.json"
      }
    ],
    "languages": [
      {
        "id": "uix",
        "aliases": [
          "UIX",
          "uix"
        ],
        "extensions": [
          ".uix"
        ],
        "icon": {
          "light": "./icons/uix-file-32.png",
          "dark": "./icons/uix-file-32.png"
        }
      }
    ],
    "snippets": [
      {
        "language": "json",
        "path": "./snippets/manifest.json"
      }
    ],
    "chatParticipants": [
      {
        "id": "dotuix.create",
        "name": "dotuix",
        "description": "Generate .uix kiosk and interactive apps with AI — no setup needed",
        "isSticky": false
      }
    ],
    "customEditors": [
      {
        "viewType": "dotuix.uixInspector",
        "displayName": "UIX Inspector",
        "selector": [
          {
            "filenamePattern": "*.uix"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
{
  "Dotuix manifest": {
    "prefix": "dotuix-manifest",
    "description": "Minimal dotuix manifest.json",
    "body": [
      "{",
      "  \"uix\": \"1.0\",",
      "  \"id\": \"com.${1:example}.${2:appname}\",",
      "  \"name\": \"${3:My App}\",",
      "  \"version\": \"1.0.0\",",
      "  \"entry\": \"index.html\",",
      "  \"mode\": \"${4|kiosk,window|}\",",
      "  \"permissions\": [],",
      "  \"network\": \"blocked\",",
      "  \"theme\": {",
      "    \"color\": \"${5:#c8a96e}\",",
      "    \"background\": \"${6:#1a1a1a}\"",
      "  }",
      "}"
    ]
  },
  "Dotuix manifest with security": {
    "prefix": "dotuix-manifest-secure",
    "description": "dotuix manifest.json with PIN auth + Ed25519 signature fields",
    "body": [
      "{",
      "  \"uix\": \"1.0\",",
      "  \"id\": \"com.${1:example}.${2:appname}\",",
      "  \"name\": \"${3:My App}\",",
      "  \"version\": \"1.0.0\",",
      "  \"entry\": \"index.html\",",
      "  \"mode\": \"kiosk\",",
      "  \"permissions\": [],",
      "  \"network\": \"blocked\",",
      "  \"expires\": \"${4:2027-01-01}\",",
      "  \"security\": {",
      "    \"auth\": \"pin\",",
      "    \"encryptedPaths\": [\"data.db\"],",
      "    \"kdf\": \"PBKDF2-SHA256\",",
      "    \"kdfIterations\": 200000,",
      "    \"keySalt\": \"${5:base64url-salt-here}\",",
      "    \"maxOpens\": ${6:10},",
      "    \"screenshot\": false",
      "  }",
      "}"
    ]
  },
  "Dotuix manifest (AI-generated)": {
    "prefix": "dotuix-manifest-ai",
    "description": "dotuix manifest.json for an AI-generated .uix — includes ai provenance block",
    "body": [
      "{",
      "  \"uix\": \"1.0\",",
      "  \"id\": \"com.${1:example}.${2:appname}\",",
      "  \"name\": \"${3:My App}\",",
      "  \"version\": \"1.0.0\",",
      "  \"entry\": \"index.html\",",
      "  \"mode\": \"${4|window,kiosk|}\",",
      "  \"network\": \"blocked\",",
      "  \"ai\": {",
      "    \"generatedBy\": \"${5:claude-opus-4}\",",
      "    \"generatedAt\": \"${6:2026-05-19T12:00:00Z}\",",
      "    \"capabilities\": [\"${7:search}\"]",
      "  }",
      "}"
    ]
  }
}